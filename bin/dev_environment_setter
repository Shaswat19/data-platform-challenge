#!/usr/bin/env bash
# =============================================================================
# bin/dev_environment_setter
#
# USAGE (must be sourced, not executed):
#   source bin/dev_environment_setter
#
# WHY source?
#   Running with `./` spawns a child shell — venv activation is lost when the
#   script exits. Using `source` runs in the current shell so the activated
#   venv persists in your terminal after the script completes.
#
# What this script does:
#   1. Guards against being executed directly (./bin/...) instead of sourced
#   2. Checks for Python 3.10+
#   3. Creates a virtual environment at .venv/
#   4. Upgrades pip inside the venv
#   5. Installs all project + dev dependencies from pyproject.toml
#   6. Installs pre-commit hooks
#   7. Verifies installed packages
#   8. Activates the virtual environment in the current shell
# =============================================================================

# ── Guard: must be sourced, not executed directly ─────────────────────────────
# When sourced, $0 is the shell name (e.g. bash, zsh).
# When executed, $0 is the script path itself.
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    echo ""
    echo "  ❌  Do not run this script directly."
    echo ""
    echo "  Use:  source bin/dev_environment_setter"
    echo ""
    exit 1
fi

# ── Colours ───────────────────────────────────────────────────────────────────
RED="\033[0;31m"
GREEN="\033[0;32m"
YELLOW="\033[1;33m"
CYAN="\033[0;36m"
RESET="\033[0m"

info()    { echo -e "${CYAN}[INFO]${RESET}  $*"; }
success() { echo -e "${GREEN}[OK]${RESET}    $*"; }
warn()    { echo -e "${YELLOW}[WARN]${RESET}  $*"; }
error()   { echo -e "${RED}[ERROR]${RESET} $*"; return 1; }

VENV_DIR=".venv"
MIN_PYTHON_MAJOR=3
MIN_PYTHON_MINOR=10

# ── 1. Locate a suitable Python interpreter ───────────────────────────────────
info "Checking Python version..."

PYTHON_BIN=""
for candidate in python3.12 python3.11 python3.10 python3 python; do
    if command -v "$candidate" &>/dev/null; then
        major=$("$candidate" -c "import sys; print(sys.version_info.major)" 2>/dev/null || echo 0)
        minor=$("$candidate" -c "import sys; print(sys.version_info.minor)" 2>/dev/null || echo 0)
        if [ "$major" -ge "$MIN_PYTHON_MAJOR" ] && [ "$minor" -ge "$MIN_PYTHON_MINOR" ]; then
            PYTHON_BIN="$candidate"
            break
        fi
    fi
done

if [ -z "$PYTHON_BIN" ]; then
    error "Python ${MIN_PYTHON_MAJOR}.${MIN_PYTHON_MINOR}+ not found.\nInstall from https://python.org and re-run."
    return 1
fi

success "Found $("$PYTHON_BIN" --version) at $(command -v "$PYTHON_BIN")"

# ── 2. Create virtual environment ─────────────────────────────────────────────
if [ -d "$VENV_DIR" ]; then
    warn "Virtual environment '${VENV_DIR}' already exists — skipping creation."
    warn "To recreate: deactivate && rm -rf ${VENV_DIR} && source bin/dev_environment_setter"
else
    info "Creating virtual environment at ${VENV_DIR}/..."
    "$PYTHON_BIN" -m venv "$VENV_DIR"
    success "Virtual environment created."
fi

# ── Resolve venv binaries (cross-platform) ────────────────────────────────────
if [ -f "${VENV_DIR}/bin/python" ]; then
    VENV_PYTHON="${VENV_DIR}/bin/python"
    VENV_ACTIVATE="${VENV_DIR}/bin/activate"
    VENV_PRECOMMIT="${VENV_DIR}/bin/pre-commit"
else
    # Windows Git Bash / MSYS2
    VENV_PYTHON="${VENV_DIR}/Scripts/python"
    VENV_ACTIVATE="${VENV_DIR}/Scripts/activate"
    VENV_PRECOMMIT="${VENV_DIR}/Scripts/pre-commit"
fi

# ── 3. Upgrade pip ────────────────────────────────────────────────────────────
info "Upgrading pip..."
"$VENV_PYTHON" -m pip install --upgrade pip --quiet
success "pip upgraded."

# ── 4. Install all dependencies ───────────────────────────────────────────────
info "Installing project + dev dependencies from pyproject.toml..."
"$VENV_PYTHON" -m pip install -e ".[dev]" --quiet
success "All dependencies installed."

# ── 5. Install pre-commit hooks ───────────────────────────────────────────────
if [ -f ".pre-commit-config.yaml" ]; then
    info "Installing pre-commit hooks..."
    "$VENV_PRECOMMIT" install
    success "pre-commit hooks installed."
else
    warn ".pre-commit-config.yaml not found — skipping pre-commit setup."
fi

# ── 6. Verify installation ────────────────────────────────────────────────────
info "Verifying installed packages..."
"$VENV_PYTHON" -c "
import pandas, requests, fsspec, s3fs, adlfs
print('  pandas  :', pandas.__version__)
print('  requests:', requests.__version__)
print('  fsspec  :', fsspec.__version__)
print('  s3fs    :', s3fs.__version__)
print('  adlfs   :', adlfs.__version__)
"
success "All core packages verified."

# ── 7. Activate the virtual environment in the current shell ──────────────────
# This works because the script is sourced — the activation persists after
# this script finishes, unlike a child-shell execution.
info "Activating virtual environment..."
# shellcheck disable=SC1090
source "$VENV_ACTIVATE"
success "Virtual environment activated: $(which python)"

# ── Done ──────────────────────────────────────────────────────────────────────
echo ""
echo -e "${GREEN}============================================${RESET}"
echo -e "${GREEN}  Dev environment ready! ${RESET}"
echo -e "${GREEN}============================================${RESET}"
echo ""
echo "  Your venv is active. You can now run:"
echo ""
echo -e "  ${CYAN}python -m steeleye.main --storage-url s3://your-bucket/instruments.csv${RESET}"
echo ""
echo -e "  ${CYAN}pytest${RESET}                 # run tests"
echo -e "  ${CYAN}ruff check .${RESET}           # lint"
echo -e "  ${CYAN}ruff format .${RESET}          # format code"
echo -e "  ${CYAN}mypy src/${RESET}              # type check"
echo ""
echo "  To deactivate:  deactivate"
echo ""
